# ════════════════════════════════════════════════════════════════════
# .env.example — plantilla de variables de entorno (commiteada, sin secretos)
# Copia a .env (gitignored) y rellena con tus valores reales.
# ════════════════════════════════════════════════════════════════════

# USDA FoodData Central API — https://fdc.nal.usda.gov/api-guide.html
VITE_USDA_API_KEY=

# Claude API — análisis de comida con IA. https://console.anthropic.com/settings/keys
VITE_CLAUDE_API_KEY=

# Supabase
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Stripe ─────────────────────────────────────────────────────────
# Cliente (segura de exponer en el bundle). Sandbox/test mientras se integra.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Server-only — NO van en el cliente ni en este repo. Se setean como secrets
# de Supabase Edge Functions (supabase secrets set ...):
#   STRIPE_SECRET_KEY=sk_test_xxx
#   STRIPE_WEBHOOK_SECRET=whsec_xxx
